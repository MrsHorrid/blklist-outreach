# .env.example — copy to .env.local and fill in values

# ─── Neon PostgreSQL ───────────────────────────────────────────────────────────
# Get these from: https://console.neon.tech → your project → Connection Details
# Use the "Pooled" URL for DATABASE_URL (serverless-safe)
DATABASE_URL="postgresql://neondb_owner:npg_h6QIRcEOWH3n@ep-sweet-night-a4aqdih1-pooler.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# Use the "Direct" URL for migrations (needed by Prisma migrate)
DIRECT_URL="postgresql://neondb_owner:npg_h6QIRcEOWH3n@ep-sweet-night-a4aqdih1-pooler.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# ─── OpenRouter ────────────────────────────────────────────────────────────────
# All AI calls (email generation, lead discovery, enrichment) go through OpenRouter.
# Get key from: https://openrouter.ai/keys
OPENROUTER_API_KEY="sk-or-..."
# Optional: override the model (default: anthropic/claude-3.5-haiku)
# OPENROUTER_MODEL="anthropic/claude-3.5-haiku"

# ─── Brave Search ──────────────────────────────────────────────────────────────
# Used by the discovery agent to find companies, emails, and LinkedIn profiles.
# Get key from: https://api.search.brave.com/
BRAVE_SEARCH_API_KEY="BSA..."

# ─── Firecrawl (optional — highly recommended) ─────────────────────────────────
# JS-rendered scraping for company team pages, about pages, etc.
# Without this key, the agent falls back to raw HTTP fetch (misses React/Next.js sites).
# Get key from: https://firecrawl.dev
# FIRECRAWL_API_KEY="fc-..."

# ─── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Optional: Email sending via Gmail ────────────────────────────────────────
# Needed only if you want real email sending (not mocked)
# GMAIL_CLIENT_ID=""
# GMAIL_CLIENT_SECRET=""
# GMAIL_REFRESH_TOKEN=""
# FROM_EMAIL="your@gmail.com"
