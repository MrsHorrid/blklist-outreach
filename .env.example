# .env.example — copy to .env.local and fill in your values

# ─── Neon PostgreSQL ───────────────────────────────────────────────────────────
# Create a free project at https://console.neon.tech
# Connection Details → copy the "Pooled connection" string for DATABASE_URL
# and the "Direct connection" string for DIRECT_URL
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.region.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST.region.aws.neon.tech/neondb?sslmode=require"

# ─── OpenRouter ────────────────────────────────────────────────────────────────
# All AI calls (email generation, lead discovery, enrichment) go through OpenRouter.
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY="sk-or-..."
# Optional: override the model used (default: anthropic/claude-3.5-haiku)
# OPENROUTER_MODEL="anthropic/claude-3.5-haiku"

# ─── Brave Search ──────────────────────────────────────────────────────────────
# Used by the discovery agent to find companies, contact info, and LinkedIn profiles.
# Get your key at https://api.search.brave.com/
BRAVE_SEARCH_API_KEY="BSA..."

# ─── Firecrawl (optional — highly recommended) ─────────────────────────────────
# JS-rendered scraping for company team pages and about pages.
# Without this key, the agent falls back to raw HTTP fetch (misses React/Next.js sites).
# Get your key at https://firecrawl.dev
# FIRECRAWL_API_KEY="fc-..."

# ─── NextAuth ──────────────────────────────────────────────────────────────────
# Generate a secret with: openssl rand -hex 32
NEXTAUTH_SECRET="your-random-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# ─── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Google OAuth (optional — for Google sign-in and Gmail linking) ────────────
# Create at https://console.cloud.google.com → APIs & Services → Credentials
# Add authorised redirect URI: http://localhost:3000/api/auth/callback/google
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# ─── Gmail sending (optional) ──────────────────────────────────────────────────
# GMAIL_CLIENT_ID=""
# GMAIL_CLIENT_SECRET=""
# GMAIL_REFRESH_TOKEN=""
# FROM_EMAIL="your@gmail.com"
