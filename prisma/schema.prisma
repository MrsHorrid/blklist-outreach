generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Lead {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company     String
  domain      String   @unique
  emoji       String?
  industry    String
  geography   String?
  companySize String?
  revenue     String?
  description String?

  contactName     String?
  contactRole     String?
  contactEmail    String?
  contactLinkedIn String?

  brandTone      String?
  signals        String[]
  adChannels     String[]
  targetAudience String?

  status   LeadStatus @default(DISCOVERED)
  score    Int        @default(0)
  source   String?
  whyFit   String?

  emails     Email[]
  notes      Note[]
  activities Activity[]

  @@index([status])
  @@index([score])
  @@index([industry])
}

model Email {
  id        String      @id @default(cuid())
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  leadId    String
  lead      Lead        @relation(fields: [leadId], references: [id], onDelete: Cascade)

  subject   String
  body      String      @db.Text
  tone      String?
  status    EmailStatus @default(DRAFT)

  sentAt    DateTime?
  openedAt  DateTime?
  repliedAt DateTime?

  trackingId String? @unique @default(cuid())
  opens      Int     @default(0)

  @@index([leadId])
  @@index([status])
}

model Note {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  content   String   @db.Text
  author    String   @default("You")

  @@index([leadId])
}

model Activity {
  id        String       @id @default(cuid())
  createdAt DateTime     @default(now())
  leadId    String
  lead      Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type      ActivityType
  detail    String?

  @@index([leadId])
}

model Settings {
  id        String   @id @default("singleton")
  updatedAt DateTime @updatedAt
  fromName  String   @default("Alex")
  fromEmail String   @default("")
  signature String   @default("Alex\nGrowth @ BLKLIST\nalex@blklist.com")
  aiModel   String   @default("claude-sonnet-4-20250514")
}

enum LeadStatus {
  DISCOVERED
  CONTACTED
  OPENED
  REPLIED
  MEETING
  CLOSED
  DISQUALIFIED
}

enum EmailStatus {
  DRAFT
  SENT
  OPENED
  REPLIED
  BOUNCED
}

enum ActivityType {
  LEAD_CREATED
  EMAIL_SENT
  EMAIL_OPENED
  EMAIL_REPLIED
  STATUS_CHANGED
  NOTE_ADDED
  MEETING_BOOKED
  ENRICHED
}
