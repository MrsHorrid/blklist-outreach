generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Auth ──────────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  name          String?

  // Business profile (used to personalise discovery)
  businessName        String?
  businessDescription String?
  pitchAngle          String?   // e.g. "We deliver 30%+ CTR for premium brands"
  targetIndustries    String[]
  targetGeographies   String[]
  targetSizes         String[]

  // Gmail OAuth connection
  gmailConnected Boolean @default(false)
  gmailEmail     String?

  accounts Account[]
  sessions Session[]
  leads    Lead[]
  tags     Tag[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Tags ──────────────────────────────────────────────────────────────────────

model Tag {
  id     String @id @default(cuid())
  name   String
  color  String @default("#6366f1")
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  leadTags LeadTag[]

  @@unique([name, userId])
}

model LeadTag {
  leadId String
  tagId  String
  lead   Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  tag    Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([leadId, tagId])
}

// ─── CRM ───────────────────────────────────────────────────────────────────────

model Lead {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Optional user ownership (null = legacy/unowned leads)
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  company     String
  domain      String   @unique
  emoji       String?
  industry    String
  geography   String?
  companySize String?
  revenue     String?
  description String?

  contactName     String?
  contactRole     String?
  contactEmail    String?
  contactLinkedIn String?

  brandTone      String?
  signals        String[]
  adChannels     String[]
  targetAudience String?

  status LeadStatus @default(DISCOVERED)
  score  Int        @default(0)
  source String?
  whyFit String?

  emails     Email[]
  notes      Note[]
  activities Activity[]
  tags       LeadTag[]

  @@index([status])
  @@index([score])
  @@index([industry])
  @@index([userId])
}

model Email {
  id        String      @id @default(cuid())
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  subject String
  body    String      @db.Text
  tone    String?
  status  EmailStatus @default(DRAFT)

  sentAt    DateTime?
  openedAt  DateTime?
  repliedAt DateTime?

  trackingId String? @unique @default(cuid())
  opens      Int     @default(0)

  @@index([leadId])
  @@index([status])
}

model Note {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  content   String   @db.Text
  author    String   @default("You")

  @@index([leadId])
}

model Activity {
  id        String       @id @default(cuid())
  createdAt DateTime     @default(now())
  leadId    String
  lead      Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type      ActivityType
  detail    String?

  @@index([leadId])
}

model Settings {
  id        String   @id @default("singleton")
  updatedAt DateTime @updatedAt
  fromName  String   @default("Alex")
  fromEmail String   @default("")
  signature String   @default("Alex\nGrowth @ BLKLIST\nalex@blklist.com")
  aiModel   String   @default("claude-sonnet-4-20250514")
}

// ─── Enums ─────────────────────────────────────────────────────────────────────

enum LeadStatus {
  DISCOVERED
  CONTACTED
  OPENED
  REPLIED
  MEETING
  CLOSED
  DISQUALIFIED
}

enum EmailStatus {
  DRAFT
  SENT
  OPENED
  REPLIED
  BOUNCED
}

enum ActivityType {
  LEAD_CREATED
  EMAIL_SENT
  EMAIL_OPENED
  EMAIL_REPLIED
  STATUS_CHANGED
  NOTE_ADDED
  MEETING_BOOKED
  ENRICHED
  TAG_ADDED
  TAG_REMOVED
}
